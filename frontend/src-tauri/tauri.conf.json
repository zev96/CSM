{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CSM",
  "version": "0.7.3",
  "identifier": "com.csm.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CSM · Content SEO Maker",
        "width": 1360,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "useHttpsScheme": false,
        "devtools": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection,CalculateNativeWinOcclusion"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost http://127.0.0.1:* http://localhost:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "category": "Productivity",
    "shortDescription": "SEO 内容自动化工具",
    "longDescription": "Tauri + Vue 3 frontend + Python (FastAPI) sidecar.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/csm-sidecar"
    ],
    "resources": [
      "binaries/updater.exe",
      "binaries/ms-playwright/"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": "^.{1,}"
    }
  }
}
