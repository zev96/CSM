{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CSM",
  "version": "0.4.0",
  "identifier": "com.csm.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CSM · Content SEO Maker",
        "width": 1652,
        "height": 1147,
        "minWidth": 1652,
        "minHeight": 1147,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: https://ipc.localhost; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc: http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Productivity",
    "shortDescription": "SEO 内容自动化工具",
    "longDescription": "Tauri + Vue 3 frontend + Python (FastAPI) sidecar.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/csm-sidecar"],
    "resources": []
  },
  "plugins": {}
}
