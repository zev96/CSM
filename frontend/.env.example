# Browser-only dev (no Tauri shell). Copy to .env.local and adjust if you
# launched a sidecar by hand via ``python -m csm_sidecar.main`` and want
# to drive it from a plain browser.
#
# When running ``npm run tauri:dev`` these are ignored — Tauri itself
# spawns the sidecar and injects the handshake.
VITE_SIDECAR_URL=http://127.0.0.1:8765
VITE_SIDECAR_TOKEN=replace-me-with-the-token-printed-on-stdout
