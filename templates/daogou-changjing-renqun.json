{
  "id": "daogou-changjing-renqun",
  "name": "导购文-科普导购文",
  "product": "吸尘器",
  "version": 1,
  "system_prompt_default": "你是资深家电导购编辑，风格为小红书笔记体：口语化、有情绪钩子、分段清晰、H2 标题明确。",
  "seo_defaults": {
    "target_word_count": [
      1500,
      2000
    ],
    "keyword_density": [
      5,
      8
    ],
    "long_tail_keywords": [],
    "tone": "小红书笔记体",
    "force_h2": true
  },
  "blocks": [
    {
      "kind": "paragraph",
      "id": "intro",
      "label": "引言-痛点共鸣",
      "source": {
        "type": "notes_query",
        "module": "引言模块",
        "filter": {
          "组件类型": "痛点共鸣"
        }
      },
      "pick_notes": 1,
      "pick_variants_per_note": 1,
      "constraints": ["unique_notes"],
      "depends_on": []
    },
    {
      "kind": "numbered_list",
      "id": "keypoints",
      "label": "科普大点",
      "source": {
        "type": "notes_query",
        "module": "科普模块/挑选攻略",
        "filter": {}
      },
      "pick_notes": 3,
      "number_style": "一、"
    },
    {
      "kind": "paragraph",
      "id": "brand_bg",
      "label": "品牌背书",
      "source": {
        "type": "notes_query",
        "module": "希喂推荐内容",
        "filter": {
          "素材类型": "品牌背书"
        }
      },
      "pick_notes": 1,
      "pick_variants_per_note": 1,
      "constraints": [],
      "depends_on": []
    },
    {
      "kind": "competitor_pool",
      "id": "brand_competitors",
      "source": {
        "type": "notes_query",
        "module": "竞品推荐内容",
        "filter": {
          "素材类型": "产品推荐理由"
        }
      },
      "pick_notes": {
        "user_configurable": true,
        "default": 2,
        "range": [1, 5]
      },
      "reason_label": "推荐理由："
    }
  ]
}
