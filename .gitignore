__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/
*.egg-info/
dist/
build/
.coverage
htmlcov/
config/settings.json
config/vault_index.cache.json
output/
templates/.trash/
*.bak
.vscode/
.idea/

csm_core/updater_client/_token.py

# GEO API 探针的原始响应转储（可能含 request_id/key，必须人工脱敏后才裁成 *.json fixture）
tests/core/monitor/geo/fixtures/*.raw.json

# scripts/dev.ps1 写入的运行时状态（sidecar/vite PID + 日志）
.csm-dev/
# scripts/dev.ps1 每次运行重新生成 handshake，不进 VCS
# 用 .env.development.local 而非 .env.local —— 前者只在 dev mode 加载，
# 不会被 `npm run tauri build` 的 vite production 模式烙进 release JS。
frontend/.env.local
frontend/.env.development.local

# vue-tsc 增量编译缓存 —— 每次 typecheck 都会被覆盖，不进 VCS
frontend/*.tsbuildinfo
frontend/tsconfig.tsbuildinfo
frontend/tsconfig.node.tsbuildinfo

# Claude Code agent worktrees —— 这些 git worktree 注册在主仓库下面，
# 否则 git status 会把每个子 worktree 误报成 deleted/modified/untracked。
.claude/worktrees/

# scripts/build_sidecar.py 的 tee log（PyInstaller 跑完留下的诊断输出）
build_sidecar.log

# Tauri externalBin + resources 落点：CI release.yml 动态生成 ——
# sidecar/updater 编译产物 + ms-playwright (~400MB chromium) 都落这里。
# 绝对不能进 VCS（chromium 体积 + 平台特定）。
frontend/src-tauri/binaries/

# Superpowers brainstorming Visual Companion 运行时产物（mockup HTML
# 文件 + 浏览器 server 状态），跨会话保留但不进 VCS。
.superpowers/

# 三平台抓取的浏览器 profile / 登录态本地落盘目录 —— 包含 cookie，
# 绝对不能进 VCS。详见 FEASIBILITY_ANALYSIS.md §2 阶段 1。
.auth/

# 外部参考代码（MediaCrawler 等）—— 只用于读架构和 vendor 取代码片段，
# 不当依赖、不进 VCS。详见 FEASIBILITY_ANALYSIS.md §2 阶段 0。
reference/
